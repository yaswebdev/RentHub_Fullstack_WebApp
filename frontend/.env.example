# ═══════════════════════════════════════════════════════════════
# RentHub Maroc — Variables d'environnement
# ───────────────────────────────────────────────────────────────
# Copiez ce fichier en ".env" et remplissez les valeurs.
# Ne jamais committer le fichier ".env" (il contient des secrets).
# ═══════════════════════════════════════════════════════════════

# ── Backend API ─────────────────────────────────────────────────
# URL de base du serveur backend.
# Laissez vide pour utiliser le mode développement local (localStorage).
# En production : https://api.renthub-maroc.ma
VITE_API_URL=

# ── Stripe (paiements) ──────────────────────────────────────────
# Clé publique Stripe (non secrète — côté client uniquement)
# TODO (Backend) : La clé secrète Stripe ne doit JAMAIS aller côté client.
VITE_STRIPE_PUBLIC_KEY=pk_test_votre_cle_publique_stripe

# ── Application ─────────────────────────────────────────────────
VITE_APP_NAME=RentHub Maroc
VITE_APP_ENV=development

# ── Notes pour le développeur backend ──────────────────────────
# Quand VITE_API_URL est défini :
#   - L'authentification utilise JWT (Bearer token)
#   - Les données viennent de votre API REST
#   - Le token est stocké dans localStorage sous la clé "renthub.token"
#   - L'intercepteur Axios attache automatiquement : Authorization: Bearer <token>
#
# Routes API attendues (voir src/constants/api.js pour la liste complète) :
#   POST   /api/auth/connexion          { email, motDePasse }  → { token, utilisateur }
#   POST   /api/auth/inscription        { nom, email, motDePasse, role } → { token, utilisateur }
#   GET    /api/proprietes              → propriete[]
#   GET    /api/proprietes/:id          → propriete
#   GET    /api/reservations/mes-reservations → reservation[]
#   POST   /api/reservations            { proprieteId, dateDebut, dateFin } → reservation
#   GET    /api/chats                   → chat[]
#   GET    /api/chats/:id/messages      → message[]
#   POST   /api/chats/:id/messages      { contenu } → message
